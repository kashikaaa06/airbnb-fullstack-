<%- layout('./layouts/boilerplate') -%>

<div class="row mt-3">
    <h1 class="col-6 offset-3">Sign Up on travelxgo</h1>
    <div class="col-6 offset-3">
     <form action="/signup" method="POST" class="needs-validation" novalidate>
        <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input id="username" name="username" type="text" class="form-control" required>
            <div class="invalid-feedback">Please provide a username.</div>
            <div class="valid-feedback">That's a good username</div>
        </div>
         <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input id="email" name="Email" type="text" class="form-control" required>
            <div class="invalid-feedback">Please provide correct email id</div>
        </div>   
        <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input id="password" name="password" type="password" class="form-control" required>
            <div class="invalid-feedback">Please provide a password.</div>
           <div class="valid-feedback">That's a good password</div>
        </div>
        <button  type="submit" class="btn btn-danger">Signup</button>
        
      </form>  
</div>
</div>