<%- layout('./layouts/boilerplate') -%>
<div class="row">
    <div class="col-8 offset-2">
        <h3><%= listing.title %></h3>
    </div>
    <div class="card col-6 offset-2 listing-card">
        <img src="<%=listing.image.url %>" class="card-img-top show-img" alt="listing_image">
        <div class="card-body">
            <p class="card-text">
                <% if (listing.owner && listing.owner.username) { %>
                    <i><%= listing.owner.username %></i>
                <% } else { %>
                    <i>Unknown User</i>
                <% } %>
                </br>
                <%= listing.description %></br>
                &#8377; <%= listing.price.toLocaleString("en-IN") %><br>
                <%= listing.country %>
            </p>
            <br><br>
        </div>
        <% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
        <div class="col-6">  
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-danger">Edit</a> <br><br>
            <form method="POST" action="/listings/<%=listing._id %>?_method=DELETE">
                <button class="btn btn-danger">Delete this listing</button>
            </form>
        </div>
      <% } %>
    </div>
  
    <div class="col-8 offset-2 mb-3">
        <% if(currUser) { %>
        <h4><b>Leave a Review</b></h4>
        <form action="/listings/<%=listing._id %>/reviews" method="POST">
            <div class="rating-container">
                <label class="rating-label">Your Rating</label>
                <div class="star-rating">
                    <input type="radio" id="star5" name="review[rating]" value="5" required />
                    <label for="star5" title="Excellent">★</label>
                    
                    <input type="radio" id="star4" name="review[rating]" value="4" />
                    <label for="star4" title="Very Good">★</label>
                    
                    <input type="radio" id="star3" name="review[rating]" value="3" />
                    <label for="star3" title="Good">★</label>
                    
                    <input type="radio" id="star2" name="review[rating]" value="2" />
                    <label for="star2" title="Fair">★</label>
                    
                    <input type="radio" id="star1" name="review[rating]" value="1" />
                    <label for="star1" title="Poor">★</label>
                </div>
            </div>
            
            <div class="mb-3 mt-3">
                <label for="comment" class="form-label">Comments</label>
                <textarea name="review[comment]" id="comment" class="form-control" rows="5" cols="5" required></textarea>
            </div>
            
            <button type="submit" class="btn btn-outline-dark">Submit Review</button>
        </form>
        <% } %>
        
        <hr>
        <h4>All Reviews (<%= listing.reviews.length %>)</h4>
        <div class="row">
            <% for(review of listing.reviews) { %>
                <div class="card col-5 ms-3 mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">
                                <i class="fas fa-user-circle"></i> 
                                <%= review.author ? review.author.username : 'Unknown User' %>
                            </h5>
                        </div>
                        <div class="review-stars my-2">
                            <% for(let i = 1; i <= 5; i++) { %>
                                <% if(i <= review.rating) { %>
                                    <i class="fas fa-star" style="color: #ffc107;"></i>
                                <% } else { %>
                                    <i class="far fa-star" style="color: #ddd;"></i>
                                <% } %>
                            <% } %>
                        </div>
                        <p class="card-text mt-2"><%= review.comment %></p>
                    </div>
                    <% if(currUser && review.author && review.author._id.equals(currUser._id)) { %>
                        <div class="card-footer">
                            <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                <button class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script src="/script.js"></script>